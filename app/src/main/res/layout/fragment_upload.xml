<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spotify_black"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/home_gradient"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Share your music with the community"
                android:textColor="#99FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── Upload Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FF1A1A1A"
            app:cardElevation="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#FF2A2A2A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Drop Zone -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/drop_zone"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FF111111"
                    app:cardElevation="0dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FF333333"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_upload"
                            app:tint="#661DB954" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tap to select audio file"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="MP3 · WAV · M4A supported"
                            android:textColor="#66FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- File selected label (hidden until file picked) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/selected_file_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FF0D2818"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#331DB954">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_play_arrow"
                            app:tint="@color/spotify_green" />

                        <TextView
                            android:id="@+id/text_selected_file"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="audio_file.mp3"
                            android:textColor="@color/spotify_green"
                            android:textSize="13sp"
                            android:maxLines="1"
                            android:ellipsize="middle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Song Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Song Title"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FF111111"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_song_title"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:inputType="textCapWords"
                        android:hint="e.g. Blinding Lights"
                        android:textColorHint="#55FFFFFF"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Artist Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Artist Name"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FF111111"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_artist_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:inputType="textCapWords"
                        android:hint="e.g. The Weeknd"
                        android:textColorHint="#55FFFFFF"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_file"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:text="Browse"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:cornerRadius="14dp"
                        app:strokeColor="#FF404040"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_search"
                        app:iconTint="@color/white"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_upload"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Upload"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textColor="@color/spotify_black"
                        android:textStyle="bold"
                        android:backgroundTint="@color/spotify_green"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_cloud_upload"
                        app:iconTint="@color/spotify_black"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />
                </LinearLayout>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progress_upload"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/spotify_green"
                    android:progressBackgroundTint="#FF333333" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Community Uploads ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="14dp">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@color/spotify_green"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Community Uploads"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_community_uploads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_library_row"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
